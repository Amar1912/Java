class Student {
    int id;
    String name;
    String branch;

    void display() {
        System.out.println(id + " " + name + " " + branch);
    }
}

public class Main {
    public static void main(String[] args) {
        Student s1 = new Student();
        s1.id = 1;
        s1.name = "Amar";
        s1.branch = "ENTC";

        s1.display();
    }
}
